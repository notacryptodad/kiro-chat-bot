# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: comma-separated Telegram user IDs allowed to use the bot
# Leave empty to allow everyone
ALLOWED_USER_IDS=

# Optional: path to kiro-cli binary (default: kiro-cli)
KIRO_CLI_PATH=kiro-cli

# Optional: working directory for Kiro sessions (default: current dir)
KIRO_WORKING_DIR=/home/user/projects

# Optional: seconds between heartbeat checks (default: 900 = 15 min)
HEARTBEAT_INTERVAL=900

# Optional: default model for new sessions (e.g. claude-sonnet-4-20250514)
# Use /model in Telegram to see available models
KIRO_DEFAULT_MODEL=
